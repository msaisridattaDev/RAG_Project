# =============================================================================
# autogen-py — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# Nested settings use __ as the delimiter (pydantic-settings convention).
# Mirrors autogen.net's appsettings.json section-for-section.
# =============================================================================

# --- Environment ---
ENV=dev

# --- App Identity (AppIdentity) ---
APP_IDENTITY__DEFAULT_APP_ID=neetpg
APP_IDENTITY__ALLOWED_APP_IDS=["neetpg","neetug","mds","ems"]

# --- Elasticsearch (Elasticsearch) ---
ELASTICSEARCH__URL=http://localhost:9200
ELASTICSEARCH__USERNAME=
ELASTICSEARCH__PASSWORD=
ELASTICSEARCH__EMBEDDING_DIM=1024

# --- Embedding Options (EmbeddingOptions) ---
EMBEDDING_OPTIONS__PROVIDER=jina
EMBEDDING_OPTIONS__BASE_URL=https://api.jina.ai/v1
EMBEDDING_OPTIONS__DEFAULT_MODEL=jina-embeddings-v3
# EMBEDDING_OPTIONS__API_KEY=sk-...

# --- Reranking Options (RerankingOptions) ---
RERANKING_OPTIONS__PROVIDER=qwen
RERANKING_OPTIONS__BASE_URL=http://home.bhakars.com:8077
RERANKING_OPTIONS__DEFAULT_MODEL=Qwen/Qwen3-Reranker-4B

# --- Cache (Cache) ---
CACHE__BASE_PATH=./cache/OpenLM
CACHE__ROTATE_DAILY=true
CACHE__MEMORY_SIZE=1000
CACHE__MEMORY_TTL_SECONDS=3600

# --- LightRAG (LightRag) ---
LIGHTRAG__NEO4J_URI=bolt://localhost:7687
LIGHTRAG__NEO4J_USER=neo4j
LIGHTRAG__NEO4J_PASSWORD=neo4j
LIGHTRAG__CHUNK_TOKEN_SIZE=960
LIGHTRAG__CHUNK_OVERLAP_TOKEN_SIZE=128
LIGHTRAG__TIKTOKEN_MODEL_NAME=cl100k_base
LIGHTRAG__ENTITY_SUMMARY_TO_MAX_TOKENS=500
LIGHTRAG__ENTITY_EXTRACT_MAX_GLEANING=1
LIGHTRAG__CHECKPOINT_PATH=./.checkpoints

# --- QnA (QnA) ---
QNA__MODELS_CATALOG_PATH=Configuration/models.json

# --- LLM Query Auth (LlmQueryAuth) ---
LLM_QUERY_AUTH__HEADER_NAME=X-LlmQuery-Token
# LLM_QUERY_AUTH__ALLOWED_TOKEN=sk-placeholder
# LLM_QUERY_AUTH__SMES=["sme1@example.com"]
# LLM_QUERY_AUTH__TESTING_USERS=["tester@example.com"]
